{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "isolatedModules": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["jest", "node"],
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "#admin/*": ["./src/admin/*"],
      "#auth/*": ["./src/auth/*"],
      "#config/*": ["./src/config/*"],
      "#market/*": ["./src/market/*"],
      "#portfolio/*": ["./src/portfolio/*"],
      "#prisma/*": ["./src/prisma/*"],
      "#profiles/*": ["./src/profiles/*"],
      "#stocks/*": ["./src/stocks/*"],
      "#trading/*": ["./src/trading/*"]
    }
  }
}
