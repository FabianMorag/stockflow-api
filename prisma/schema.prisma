// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  BUY
  SELL
}

enum Role {
  TRADER
  ADMIN
}

model Profile {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  balance   Decimal  @default(10000) @db.Decimal(12, 2)
  role      Role     @default(TRADER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  holdings     Holding[]

  @@map("profiles")
}

model Stock {
  ticker       String        @id
  name         String
  currentPrice Decimal       @db.Decimal(12, 2)
  lastUpdated  DateTime      @default(now())
  createdAt    DateTime      @default(now())

  transactions Transaction[]
  holdings     Holding[]
  snapshots    PriceSnapshot[]

  @@map("stocks")
}

model Transaction {
  id                String          @id @default(uuid())
  profileId         String
  stockTicker       String
  type              TransactionType
  quantity          Decimal         @db.Decimal(12, 6)
  priceAtExecution  Decimal         @db.Decimal(12, 2)
  totalAmount       Decimal         @db.Decimal(12, 2)
  timestamp         DateTime        @default(now())

  profile  Profile @relation(fields: [profileId], references: [id])
  stock    Stock   @relation(fields: [stockTicker], references: [ticker])

  @@index([profileId])
  @@index([stockTicker])
  @@index([timestamp])
  @@map("transactions")
}

model Holding {
  id                   String   @id @default(uuid())
  profileId            String
  stockTicker          String
  quantity             Decimal  @db.Decimal(12, 6)
  averagePurchasePrice Decimal  @db.Decimal(12, 2)
  updatedAt            DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id])
  stock   Stock   @relation(fields: [stockTicker], references: [ticker])

  @@unique([profileId, stockTicker])
  @@index([profileId])
  @@index([stockTicker])
  @@map("holdings")
}

model PriceSnapshot {
  id        String   @id @default(uuid())
  stockTicker String
  price     Decimal  @db.Decimal(12, 2)
  recordedAt DateTime @default(now())

  stock Stock @relation(fields: [stockTicker], references: [ticker], onDelete: Cascade)

  @@index([stockTicker])
  @@index([recordedAt])
  @@map("price_snapshots")
}
