# PostgreSQL connection string (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/stockflow

# Supabase project URL for JWT validation (optional, required if using Supabase for authentication)
SUPABASE_URL=https://your-project.supabase.co

# Server port (optional, defaults to 3000)
PORT=3000

# Allowed CORS origin (optional, defaults to http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
